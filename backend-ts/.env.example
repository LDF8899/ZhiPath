# ── MySQL ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=zhipath

# ── MongoDB ──
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DATABASE=zhipath

# ── Redis ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Neo4j ──
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ── LLM ──
# 可选: ollama | openai | deepseek
LLM_PROVIDER=ollama
# Ollama (本地)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# OpenAI 兼容 API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# DeepSeek (OpenAI 兼容端点)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro          # 推理模型：出题、生成讲义、编程题
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash   # 快速模型：意图路由、日常聊天、画像分析

# ── GitHub ──
GITHUB_TOKEN=

# ── 多模态智能体 (T5) ──
# 智谱 AI — 短视频生成 (CogVideoX)，缺省时短视频模态优雅降级
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_VIDEO_MODEL=cogvideox
# 讯飞 — 数字人讲解 (RTCPlayer 虚拟人)，缺省时数字人模态优雅降级
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_AVATAR_ID=110017
XFYUN_SERVICE_ID=

# ── App ──
APP_HOST=0.0.0.0
APP_PORT=3000
SECRET_KEY=change-me-in-production
JWT_EXPIRES_IN=7d
DEBUG=false

# ── SearXNG ──
SEARXNG_URL=http://127.0.0.1:8080
NEWS_FETCH_INTERVAL=14400
NEWS_FETCH_ENABLED=true

# ── MinIO ──
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zhipath
